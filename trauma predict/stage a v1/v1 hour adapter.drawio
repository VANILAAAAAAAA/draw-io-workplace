        <mxCell id="tDpAH2ogk-71bGu28_fL-63" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;div style=&quot;line-height: 40%;&quot;&gt;&lt;h3 style=&quot;line-height: 40%;&quot;&gt;&lt;br&gt;&lt;/h3&gt;&lt;h3 style=&quot;line-height: 40%;&quot;&gt;&lt;font style=&quot;font-size: 10px; line-height: 40%;&quot;&gt;Step C: Linear → LN → 768-D hour-state embedding&lt;/font&gt;&lt;/h3&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;\[&lt;br&gt;\mathbf e_h^{\mathrm{state}}&lt;br&gt;=&lt;br&gt;\operatorname{LN}&lt;br&gt;\left(&lt;br&gt;W_2\mathbf q_h+b_2&lt;br&gt;\right)&lt;br&gt;\in\mathbb R^{768}&lt;br&gt;\]&lt;/font&gt;&lt;h3 style=&quot;line-height: 40%;&quot;&gt;&lt;font style=&quot;font-size: 10px; line-height: 40%;&quot;&gt;Step D: + token + relative time + HOUR segment&lt;/font&gt;&lt;/h3&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;\[&lt;br&gt;\mathbf e_h^{\mathrm{HOUR}}&lt;br&gt;=&lt;br&gt;E^{\mathrm{token}}(\langle H_h\rangle)&lt;br&gt;+&lt;br&gt;\mathbf e_h^{\mathrm{state}}&lt;br&gt;+&lt;br&gt;E^{\mathrm{time}}(h)&lt;br&gt;+&lt;br&gt;E^{\mathrm{segment}}(\mathrm{HOUR})&lt;br&gt;\in\mathbb R^{768}&lt;br&gt;\]&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="455" x="555" y="1060" as="geometry" />
        </mxCell>
        <mxCell id="tDpAH2ogk-71bGu28_fL-64" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;h3 style=&quot;line-height: 5.616px;&quot;&gt;&lt;font style=&quot;font-size: 10px; line-height: 5.2px;&quot;&gt;Step A: Field-aware encoding + concatenate → 512-D&lt;/font&gt;&lt;/h3&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;\[&lt;br&gt;\mathbf z_{h,f}&lt;br&gt;=&lt;br&gt;\operatorname{LN}&lt;br&gt;\left(&lt;br&gt;W_f(\tilde{x}_{h,f}m_{h,f})+b_f&lt;br&gt;+&lt;br&gt;E_f^{\mathrm{mask}}(m_{h,f})&lt;br&gt;+&lt;br&gt;E^{\mathrm{field}}(f)&lt;br&gt;\right)&lt;br&gt;\in\mathbb R^{64}&lt;br&gt;\]\[&lt;br&gt;\mathbf z_{h,\mathrm{vent}}&lt;br&gt;=&lt;br&gt;\operatorname{LN}&lt;br&gt;\left(&lt;br&gt;E^{\mathrm{vent}}(v_h)&lt;br&gt;+&lt;br&gt;E^{\mathrm{field}}(\mathrm{vent})&lt;br&gt;\right)&lt;br&gt;\in\mathbb R^{64}&lt;br&gt;\]\[&lt;br&gt;\mathbf u_h&lt;br&gt;=&lt;br&gt;\operatorname{Concat}&lt;br&gt;\left(&lt;br&gt;\mathbf z_{h,1},\ldots,\mathbf z_{h,7},&lt;br&gt;\mathbf z_{h,\mathrm{vent}}&lt;br&gt;\right)&lt;br&gt;\in\mathbb R^{512}&lt;br&gt;\]&lt;/font&gt;&lt;h3 style=&quot;line-height: 5.616px;&quot;&gt;&lt;font style=&quot;font-size: 10px; line-height: 5.2px;&quot;&gt;Step B: LN → Linear → GELU → Dropout → 256-D&lt;/font&gt;&lt;/h3&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;\[&lt;br&gt;\mathbf q_h&lt;br&gt;=&lt;br&gt;\operatorname{Dropout}&lt;br&gt;\left(&lt;br&gt;\operatorname{GELU}&lt;br&gt;\left(&lt;br&gt;W_1\operatorname{LN}(\mathbf u_h)+b_1&lt;br&gt;\right)&lt;br&gt;\right)&lt;br&gt;\in\mathbb R^{256}&lt;br&gt;\]&lt;/font&gt;" vertex="1">
          <mxGeometry height="30" width="410" x="110" y="1100" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
