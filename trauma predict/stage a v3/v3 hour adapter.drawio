        <mxCell id="FI1zoEiiq-ei2-4clDeo-45" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 15px;&quot;&gt;×24 hours → 168 Field-Hour Tokens&lt;/font&gt;" vertex="1">
          <mxGeometry height="30" width="250" x="1140" y="800" as="geometry" />
