        <mxCell id="FI1zoEiiq-ei2-4clDeo-46" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;div style=&quot;line-height: 50%;&quot;&gt;&lt;p&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;Vital representation：&lt;/font&gt;&lt;/p&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;\[&lt;br&gt;\mathbf z_{h,f}&lt;br&gt;=&lt;br&gt;\operatorname{LN}_{64}&lt;br&gt;\left(&lt;br&gt;W_f(\tilde{x}_{h,f}m_{h,f})+b_f&lt;br&gt;+&lt;br&gt;E_f^{mask}(m_{h,f})&lt;br&gt;+&lt;br&gt;E^{field}(f)&lt;br&gt;\right)&lt;br&gt;\in\mathbb R^{64}&lt;br&gt;\]&lt;/font&gt;&lt;p&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;Vent representation：&lt;/font&gt;&lt;/p&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;\[&lt;br&gt;\mathbf z_{h,v}&lt;br&gt;=&lt;br&gt;\operatorname{LN}_{64}&lt;br&gt;\left(&lt;br&gt;E^{vent}(v_h)&lt;br&gt;+&lt;br&gt;E^{field}(\mathrm{vent})&lt;br&gt;\right)&lt;br&gt;\in\mathbb R^{64}&lt;br&gt;\]&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="490" x="130" y="1030" as="geometry" />
        </mxCell>
        <mxCell id="FI1zoEiiq-ei2-4clDeo-48" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;Step A&lt;/b&gt;: \(\mathbf u_{h,f}&lt;br&gt;=&lt;br&gt;\operatorname{Concat}&lt;br&gt;\left(&lt;br&gt;\mathbf 0_{64},\ldots,&lt;br&gt;\mathbf z_{h,f},&lt;br&gt;\ldots,\mathbf 0_{64},&lt;br&gt;\mathbf z_{h,v}&lt;br&gt;\right)&lt;br&gt;\in\mathbb R^{512}\)" vertex="1">
          <mxGeometry height="30" width="380" x="130" y="1110" as="geometry" />
        </mxCell>
        <mxCell id="FI1zoEiiq-ei2-4clDeo-49" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;div style=&quot;line-height: 50%;&quot;&gt;&lt;h3 style=&quot;line-height: 50%;&quot;&gt;&lt;font style=&quot;font-size: 10px; line-height: 50%;&quot;&gt;Step B：512 → 256&lt;/font&gt;&lt;/h3&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;\[&lt;br&gt;\mathbf q_{h,f}&lt;br&gt;=&lt;br&gt;\operatorname{Dropout}&lt;br&gt;\left[&lt;br&gt;\operatorname{GELU}&lt;br&gt;\left(&lt;br&gt;W_1\operatorname{LN}_{512}(\mathbf u_{h,f})+b_1&lt;br&gt;\right)&lt;br&gt;\right]&lt;br&gt;\in\mathbb R^{256}&lt;br&gt;\]&lt;/font&gt;&lt;h3 style=&quot;line-height: 50%;&quot;&gt;&lt;font style=&quot;font-size: 10px; line-height: 50%;&quot;&gt;Step C：256 → 768 Field-Hour State&lt;/font&gt;&lt;/h3&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;\[&lt;br&gt;\mathbf e_{h,f}^{state}&lt;br&gt;=&lt;br&gt;\operatorname{LN}_{768}&lt;br&gt;\left(&lt;br&gt;W_2\mathbf q_{h,f}+b_2&lt;br&gt;\right)&lt;br&gt;\in\mathbb R^{768}&lt;br&gt;\]&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="370" x="605" y="1020" as="geometry" />
        </mxCell>
        <mxCell id="FI1zoEiiq-ei2-4clDeo-50" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;div style=&quot;line-height: 50%;&quot;&gt;&lt;h3 style=&quot;line-height: 50%;&quot;&gt;&lt;font style=&quot;font-size: 10px; line-height: 50%;&quot;&gt;Step D：&lt;/font&gt;&lt;/h3&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;\[&lt;br&gt;\mathbf e_{h,f}^{HOUR}&lt;br&gt;=&lt;br&gt;E^{token}(\langle H_h\rangle)&lt;br&gt;+&lt;br&gt;\mathbf e_{h,f}^{state}&lt;br&gt;+&lt;br&gt;E^{time}(h)&lt;br&gt;+&lt;br&gt;E^{segment}(\mathrm{HOUR})&lt;br&gt;\in\mathbb R^{768}&lt;br&gt;\]&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="360" x="605" y="1110" as="geometry" />
        </mxCell>
      </root>
